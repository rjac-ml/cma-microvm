# Launcher configuration (Twelve-Factor Factor III: config in the environment).
# Copy to `.env` for local use; never commit real secret values.

# --- Required dispatch config (non-secret) ---
ANTHROPIC_ENVIRONMENT_ID=env_replace_me
MICROVM_IMAGE_IDENTIFIER=img_replace_me
MICROVM_EXECUTION_ROLE_ARN=arn:aws:iam::123456789012:role/microvm-exec
ENVIRONMENT_KEY_SECRET_ARN=arn:aws:secrets:us-west-2:123456789012:secret:envkey
AWS_REGION=us-west-2

# --- Optional ---
# Signature verification is SKIPPED when SIGNING_SECRET_ARN is unset.
SIGNING_SECRET_ARN=
ANTHROPIC_BASE_URL=
MAX_LIFETIME_SECONDS=28800
LAUNCH_TPS_LIMIT=5

# --- Local-only ---
LAUNCHER_USE_STUB=1
# When set, webhook dedup uses this DynamoDB table (Powertools idempotency).
IDEMPOTENCY_TABLE=
# Points boto3 at DynamoDB Local (docker compose).
AWS_ENDPOINT_URL_DYNAMODB=